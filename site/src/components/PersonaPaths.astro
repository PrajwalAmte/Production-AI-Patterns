---
const paths = [
  {
    label: "Building a RAG system",
    description:
      "Retrieve from your own data reliably with structured, searchable pipelines.",
    pillars: [
      {
        name: "Retrieval & Memory",
        href: "/AI-Engineering-Patterns/patterns/retrieval-and-memory/",
      },
      {
        name: "Data Patterns",
        href: "/AI-Engineering-Patterns/patterns/data-patterns/",
      },
      {
        name: "Graph Patterns",
        href: "/AI-Engineering-Patterns/patterns/graph-patterns/",
      },
      {
        name: "Evaluation & Testing",
        href: "/AI-Engineering-Patterns/patterns/evaluation-and-testing/",
      },
    ],
    start: "/AI-Engineering-Patterns/patterns/retrieval-and-memory/",
  },
  {
    label: "Deploying to production",
    description:
      "Make AI services reliable, cost-efficient, and observable at scale.",
    pillars: [
      {
        name: "Inference & Serving",
        href: "/AI-Engineering-Patterns/patterns/inference-and-serving/",
      },
      {
        name: "Reliability & Resilience",
        href: "/AI-Engineering-Patterns/patterns/reliability/",
      },
      {
        name: "Observability",
        href: "/AI-Engineering-Patterns/patterns/observability/",
      },
      {
        name: "Cost & Efficiency",
        href: "/AI-Engineering-Patterns/patterns/cost-and-efficiency/",
      },
    ],
    start: "/AI-Engineering-Patterns/patterns/inference-and-serving/",
  },
  {
    label: "Governance & safety",
    description:
      "Audit, document, and harden AI systems for compliance and trust.",
    pillars: [
      {
        name: "Security & Trust",
        href: "/AI-Engineering-Patterns/patterns/security-and-trust/",
      },
      {
        name: "Governance",
        href: "/AI-Engineering-Patterns/patterns/governance/",
      },
      {
        name: "Evaluation & Testing",
        href: "/AI-Engineering-Patterns/patterns/evaluation-and-testing/",
      },
      {
        name: "Observability",
        href: "/AI-Engineering-Patterns/patterns/observability/",
      },
    ],
    start: "/AI-Engineering-Patterns/patterns/security-and-trust/",
  },
];
---

<div class="persona-grid not-content">
  {
    paths.map((path) => (
      <div class="persona-card">
        <div class="persona-label">{path.label}</div>
        <div class="persona-desc">{path.description}</div>
        <div class="persona-tags">
          {path.pillars.map((pillar) => (
            <a href={pillar.href} class="persona-tag">
              {pillar.name}
            </a>
          ))}
        </div>
        <div class="persona-spacer"></div>
        <a href={path.start} class="persona-cta">Start here</a>
      </div>
    ))
  }
</div>
